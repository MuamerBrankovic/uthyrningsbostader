generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bostad {
  id                   String   @id @default(uuid())
  namn                 String
  adress               String?
  stadsdel             String?
  beskrivning          String?
  bilder               String[]
  delade_utrymmen      String[]
  inkluderat           String[]
  narmaste_hallplats   String?
  bostadstyp           String   @default("privat_rum")
  kontaktperson_namn   String?
  kontaktperson_bild   String?
  kontaktperson_email  String?
  kontaktperson_telefon String?
  rum                  Rum[]
  created_at           DateTime @default(now())
}

model Hyresvardsanmalan {
  id          String   @id @default(uuid())
  namn        String
  telefon     String?
  email       String
  stad        String?
  adress      String?
  meddelande  String?
  // Lead-uppföljning (admin) — obehandlad | kontaktad | pagaende | avtal_klart | ej_aktuell
  status          String    @default("obehandlad")
  intern_notering String?   @db.Text
  uppdaterad      DateTime?
  created_at  DateTime @default(now())
}

model Rum {
  id          String     @id @default(uuid())
  bostad_id   String
  bostad      Bostad     @relation(fields: [bostad_id], references: [id], onDelete: Cascade)
  namn        String
  beskrivning String?
  bilder      String[]
  kvm         Int?
  manadshyra  Int
  moblering   String[]
  status      String     @default("ledig")
  bokningar   Bokning[]
  created_at  DateTime   @default(now())
}

model Bokning {
  id                 String   @id @default(uuid())
  rum_id             String
  rum                Rum      @relation(fields: [rum_id], references: [id], onDelete: Cascade)
  // Sätts när en inloggad användare bokar — "Mina bokningar" filtrerar på
  // denna (aldrig på e-post, som går att kapa via overifierad registrering)
  anvandare_id       String?
  anvandare          Anvandare? @relation(fields: [anvandare_id], references: [id], onDelete: SetNull)
  kund_foretag       String?
  kund_orgnr         String?
  kund_kontaktperson String
  boende_namn        String?
  email              String
  telefon            String?
  startdatum         DateTime
  slutdatum          DateTime?
  status             String   @default("forfragan")
  avtalstyp          String   @default("standard")
  // Kontrakthantering (admin) — saknas | uppladdat | skickat | signerat
  kontrakt_url         String?
  kontrakt_status      String    @default("saknas")
  kontrakt_uppdaterad  DateTime?
  // Fakturering (admin, platshållare) — ej_fakturerad | fakturerad | betald
  faktura_status       String    @default("ej_fakturerad")
  created_at         DateTime @default(now())

  @@index([anvandare_id])
}

model Anvandare {
  id           String   @id @default(uuid())
  email        String   @unique
  losenord     String
  namn         String
  roll         String   @default("hyresgast")
  bokningar    Bokning[]
  created_at   DateTime @default(now())
}

model Offertforfragan {
  id              String    @id @default(uuid())
  foretag         String
  orgnr           String?
  kontaktperson   String
  email           String
  telefon         String
  stad            String
  antal_personer  Int?
  inflyttning     DateTime?
  bostadstyp      String?
  meddelande      String?
  // Lead-uppföljning (admin) — obehandlad | kontaktad | offert_skickad | vunnen | forlorad
  // (äldre rader kan ha legacy-värdet "ny" — UI behandlar det som "obehandlad")
  status          String    @default("obehandlad")
  intern_notering String?   @db.Text
  uppdaterad      DateTime?
  created_at      DateTime  @default(now())
}